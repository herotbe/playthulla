# Copy this file to `.env.local` and fill in real values.
# Anything prefixed VITE_ is exposed to the browser bundle — do not put secrets here.
# Server-side secrets (service role key, etc.) NEVER go in .env files prefixed VITE_.

# Supabase — get these from https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
